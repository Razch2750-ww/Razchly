{
  "entities": {
    "User": {
      "title": "User Settings",
      "description": "User specific settings including theme and language.",
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "Account": {
      "title": "Financial Account",
      "description": "Represents a bank account or wallet.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "balance"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Record of income, expense, or transfer.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
        "amount": { "type": "number" },
        "accountId": { "type": "string" },
        "fromAccountId": { "type": "string" },
        "toAccountId": { "type": "string" },
        "adminFee": { "type": "number" },
        "adminFeeChargeTo": { "type": "string", "enum": ["origin", "destination"] },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "categoryIcon": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    },
    "Category": {
      "title": "Expense/Income Category",
      "description": "Categories for categorizing transactions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "icon", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "User's categories for transactions"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile and settings"
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": { "$ref": "#/entities/Account" },
      "description": "User's financial accounts"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User's transactions"
    }
  }
}
